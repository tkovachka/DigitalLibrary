@model IEnumerable<LibraryApplication.Domain.Domain.Publisher>
@{
    ViewData["Title"] = "Publishers";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-2">
    <div>
        <p class="section-eyebrow">Browse</p>
        <h1 style="margin-bottom:0">Publishers</h1>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="admin-bar" style="margin-bottom:0">
            <span class="admin-bar__label">Admin</span>
            <a asp-action="Create" class="btn btn-success btn-sm">+ Add Publisher</a>
            <a asp-action="Delete" class="btn btn-danger btn-sm">✕ Delete All</a>
        </div>
    }
</div>
<hr />

@if (!Model.Any())
{
    <div class="empty-state"><span class="empty-state-icon">🏢</span><h3>No publishers yet</h3></div>
}
else
{
    <div class="entity-list">
        @foreach (var item in Model)
        {
            <div class="entity-list-item">
                <span class="entity-list-item__name">@item.Name</span>
                <div class="entity-list-item__actions">
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    }
                </div>
            </div>
        }
    </div>
}