@model LibraryApplication.Domain.Domain.Loan
@{
    ViewData["Title"] = "Return Book";
    var due = Model.DateBorrowed.AddDays(14);
    var left = due.DayNumber - DateOnly.FromDateTime(DateTime.UtcNow).DayNumber;
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← My Loans</a>
<p class="section-eyebrow">Confirm Return</p>
<h1>Return This Book</h1>
<hr />

<div class="confirm-panel">
    <div class="confirm-book-strip">
        @if (!string.IsNullOrWhiteSpace(Model.BorrowedBook?.ThumbnailUrl))
        {
            <img src="@Model.BorrowedBook.ThumbnailUrl" alt="" />
        }
        <div class="confirm-book-meta">
            <h3>@Model.BorrowedBook?.Title</h3>
            <p>Borrowed: @Model.DateBorrowed</p>
            <p>
                Due: @due
                @if (left >= 0)
                {
                    <span style="color:var(--success);font-weight:700"> — @left days remaining</span>
                }
                else
                {

                    <span style="color:var(--danger);font-weight:700"> — Overdue</span>
                }
            </p>
        </div>
    </div>
    <form asp-action="ReturnConfirmation" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-warning btn-lg">Confirm Return</button>
        <a asp-action="Index" asp-controller="Books" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>