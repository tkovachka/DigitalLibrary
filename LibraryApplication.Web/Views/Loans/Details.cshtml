@model LibraryApplication.Domain.Domain.Loan
@{
    ViewData["Title"] = "Loan Details";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← My Loans</a>
<p class="section-eyebrow">Loan Details</p>
<h1>@Model.BorrowedBook?.Title</h1>
<hr />

<div class="confirm-panel">
    <div class="confirm-book-strip">
        @if (!string.IsNullOrWhiteSpace(Model.BorrowedBook?.ThumbnailUrl))
        {
            <img src="@Model.BorrowedBook.ThumbnailUrl" alt="" />
        }
        <div class="confirm-book-meta">
            <h3>@Model.BorrowedBook?.Title</h3>
            <p>Borrowed: @Model.DateBorrowed</p>
            @if (Model.DateReturned != null)
            {
                <p>Returned: @Model.DateReturned</p>
            }
            else
            {

                <p style="color:var(--success);font-weight:600">Active loan</p>
            }
        </div>
    </div>
    @if (Model.DateReturned == null)
    {
        <form method="post" asp-action="Return" class="d-flex gap-2">
            <input hidden name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-warning">Return Book</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </form>
    }
    else
    {

        <a asp-action="Index" class="btn btn-outline-secondary">Back to My Loans</a>
    }
</div>