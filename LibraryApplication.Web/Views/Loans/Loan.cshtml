@using LibraryApplication.Domain.Domain
@model Book
@{
    ViewData["Title"] = "Borrow Book";
}

<a asp-action="Index" asp-controller="Books" class="btn btn-outline-secondary btn-sm mb-3">← Back to Books</a>
<p class="section-eyebrow">Confirm Loan</p>
<h1>Borrow This Book</h1>
<hr />

<div class="confirm-panel">
    <div class="confirm-book-strip">
        @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
        {
            <img src="@Model.ThumbnailUrl" alt="@Model.Title" />
        }
        <div class="confirm-book-meta">
            <h3>@Model.Title</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
            {
                <p>@Model.Subtitle</p>
            }
            @if (Model.Authors.Any())
            {
                <p>by @string.Join(", ", Model.Authors.Select(a => a.Name))</p>
            }
            @if (Model.Publisher != null)
            {
                <p>@Model.Publisher.Name@(Model.PublishedDate.HasValue ? $" · {Model.PublishedDate.Value.Year}" : "")</p>
            }
            @if (Model.PageCount.HasValue)
            {
                <p>@Model.PageCount pages</p>
            }
        </div>
    </div>
    <div class="rules-box">
        <h4>Borrowing Rules</h4>
        <ul>
            <li>You have <strong>14 days</strong> to read and return this book.</li>
            <li>You may return early — others may be waiting in queue.</li>
            <li>After 14 days, the loan expires automatically.</li>
        </ul>
    </div>
    <form asp-action="LoanConfirm" method="post" class="d-flex gap-2">
        <input type="hidden" name="bookId" value="@Model.Id" />
        <input type="hidden" name="reservationId" value="@ViewBag.ReservationId" />
        <button type="submit" class="btn btn-success btn-lg">Confirm Borrow</button>
        <a asp-action="Index" asp-controller="Books" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>