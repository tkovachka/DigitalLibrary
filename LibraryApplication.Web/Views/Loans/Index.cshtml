@model IEnumerable<LibraryApplication.Domain.Domain.Loan>
@{
    ViewData["Title"] = "My Loans"; var history = ViewBag.History as List<LibraryApplication.Domain.Domain.Loan>;
}

<p class="section-eyebrow">My Account</p>
<h1>My Loans</h1>
<hr />

@if (Model != null && Model.Any())
{
    <table class="table-folio mb-4">
        <thead>
            <tr><th></th><th>Book</th><th>Borrowed</th><th>Due</th><th>Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var due = item.DateBorrowed.AddDays(14);
                var left = due.DayNumber - DateOnly.FromDateTime(DateTime.UtcNow).DayNumber;
                <tr>
                    <td><img class="book-thumb" src="@item.BorrowedBook?.ThumbnailUrl" alt="" /></td>
                    <td><strong style="font-family:'Cormorant Garamond',serif;font-size:1.05rem">@item.BorrowedBook?.Title</strong></td>
                    <td>@item.DateBorrowed</td>
                    <td>
                        @if (left > 3)
                        {
                            <span style="color:var(--success);font-weight:700">@left days left</span>
                        }
                        else if (left >= 0)
                        {

                            <span style="color:var(--danger);font-weight:700">@left days left!</span>
                        }
                        else
                        {

                            <span style="color:var(--danger);font-weight:700">Overdue</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-2">
                            <a class="btn btn-warning btn-sm" asp-action="Return" asp-route-id="@item.Id">Return</a>
                            <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.Id">Details</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="empty-state">
        <span class="empty-state-icon">📭</span>
        <h3>No active loans</h3>
        <p><a asp-action="Index" asp-controller="Books">Browse books</a> to start borrowing.</p>
    </div>
}

<h2 style="margin-top:2.5rem">History</h2>
<hr />
@if (history != null && history.Any())
{
    <table class="table-folio">
        <thead>
            <tr><th></th><th>Book</th><th>Borrowed</th><th>Returned</th></tr>
        </thead>
        <tbody>
            @foreach (var item in history)
            {
                <tr>
                    <td><img class="book-thumb" src="@item.BorrowedBook?.ThumbnailUrl" alt="" /></td>
                    <td><strong style="font-family:'Cormorant Garamond',serif">@item.BorrowedBook?.Title</strong></td>
                    <td>@item.DateBorrowed</td>
                    <td>@item.DateReturned</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{

    <p style="color:var(--text-muted);font-size:.9rem">No finished loans yet.</p>
}