@model List<Book>
@{
    ViewData["Title"] = "Books";
    @using LibraryApplication.Domain.Domain
    @using Microsoft.AspNetCore.Identity
@inject UserManager<LibraryApplication.Domain.Identity.LibraryApplicationUser> UserManager
}

<div class="d-flex align-items-start justify-content-between flex-wrap gap-3 mb-2">
    <div>
        <p class="section-eyebrow mb-1">Collection</p>
        <h1 style="margin-bottom:0">All Books</h1>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="admin-bar" style="margin-bottom:0">
            <span class="admin-bar__label">Admin</span>
            <a asp-action="Create" class="btn btn-success btn-sm">+ Add Book</a>
            <a asp-action="Import" class="btn btn-outline-success btn-sm">↓ Import</a>
            <a asp-action="Delete" class="btn btn-danger btn-sm">✕ Delete All</a>
        </div>
    }
</div>
<hr />

@if (!Model.Any())
{
    <div class="empty-state">
        <span class="empty-state-icon">📚</span>
        <h3>No books yet</h3>
        <p>The collection is empty.</p>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Import" class="btn btn-primary">Import from Google Books</a>
        }
    </div>
}
else
{
    <div class="books-grid">
        @foreach (var item in Model)
        {
            <div class="book-card">
                <div class="book-card__cover">
                    @if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                    {
                        <img src="@item.ThumbnailUrl" alt="@item.Title" loading="lazy" />
                    }
                    else
                    {
                        <span class="book-card__cover-placeholder">📖</span>
                    }
                    <span class="book-card__availability @(item.IsAvailable ? "badge-available" : "badge-unavailable")">
                        @(item.IsAvailable ? "Available" : "On Loan")
                    </span>
                </div>
                <div class="book-card__body">
                    <div class="book-card__title">@item.Title</div>
                    @if (item.Authors.Any())
                    {
                        <div class="book-card__author">@string.Join(", ", item.Authors.Select(a => a.Name))</div>
                    }
                    <div class="book-card__cats">
                        @foreach (var cat in item.Categories.Take(2))
                        {
                            <span class="badge badge-burgundy">@cat.Name</span>
                        }
                    </div>
                </div>
                <div class="book-card__footer">
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    }
                </div>
            </div>
        }
    </div>
}