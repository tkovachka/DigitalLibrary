@using LibraryApplication.Domain.Domain
@model Book
@{
    ViewData["Title"] = "Edit Book";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back to Books</a>
<p class="section-eyebrow">Admin</p>
<h1>Edit Book</h1>
<hr />

<div class="form-section">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col-md-6 form-group">
                <label asp-for="Isbn10" class="control-label">ISBN-10</label>
                <input asp-for="Isbn10" class="form-control" />
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="Isbn13" class="control-label">ISBN-13</label>
                <input asp-for="Isbn13" class="form-control" />
            </div>
        </div>
        <div class="form-group">
            <label asp-for="Title" class="control-label">Title</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger" style="font-size:.8rem"></span>
        </div>
        <div class="form-group">
            <label asp-for="Subtitle" class="control-label">Subtitle</label>
            <input asp-for="Subtitle" class="form-control" />
        </div>
        <div class="row">
            <div class="col-md-6 form-group">
                <label asp-for="PublishedDate" class="control-label">Published Date</label>
                <input asp-for="PublishedDate" type="date" class="form-control" />
            </div>
            <div class="col-md-6 form-group">
                <label asp-for="PageCount" class="control-label">Page Count</label>
                <input asp-for="PageCount" class="form-control" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 form-group">
                <label asp-for="Language" class="control-label">Language</label>
                <input asp-for="Language" class="form-control" placeholder="en" />
            </div>
            <div class="col-md-4 form-group">
                <label asp-for="AverageRating" class="control-label">Rating (0–5)</label>
                <input asp-for="AverageRating" class="form-control" type="number" step="0.1" min="0" max="5" />
            </div>
            <div class="col-md-4 form-group">
                <label asp-for="RatingsCount" class="control-label">Ratings Count</label>
                <input asp-for="RatingsCount" class="form-control" />
            </div>
        </div>
        <div class="form-group">
            <label asp-for="Description" class="control-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>
        <div class="form-group">
            <label asp-for="ThumbnailUrl" class="control-label">Cover Image URL</label>
            <input asp-for="ThumbnailUrl" class="form-control" placeholder="https://..." />
        </div>
        <hr />
        <div class="form-group">
            <label class="control-label">Publisher</label>
            <select asp-for="PublisherId" class="form-control form-select" asp-items="ViewBag.Publishers"></select>
        </div>
        <div class="form-group">
            <label class="control-label">Authors <small style="text-transform:none;font-weight:300">(Ctrl+click for multiple)</small></label>
            <select asp-for="AuthorIds" class="form-control form-select" multiple asp-items="ViewBag.Authors" style="height:120px"></select>
        </div>
        <div class="form-group">
            <label class="control-label">Genres <small style="text-transform:none;font-weight:300">(Ctrl+click for multiple)</small></label>
            <select asp-for="CategoryIds" class="form-control form-select" multiple asp-items="ViewBag.Categories" style="height:120px"></select>
        </div>
        <hr />
        <div class="d-flex gap-2">
            <input type="submit" value="Save Changes" class="btn btn-success" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}