@using LibraryApplication.Domain.Domain
@model Book
@{
    ViewData["Title"] = "Delete Book"; bool deleteAll = ViewData["DeleteAll"] != null;
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back to Books</a>
<h1>@(deleteAll ? "Delete All Books" : "Delete Book")</h1>
<hr />

@if (deleteAll)
{
    <div class="folio-card" style="max-width:500px">
        <div class="folio-card-header" style="background:var(--danger)">⚠ Confirm Delete All</div>
        <div class="folio-card-body">
            <p>This will permanently delete <strong>every book</strong> in the library. This cannot be undone.</p>
            <form asp-action="Delete" method="post" class="d-flex gap-2">
                @Html.AntiForgeryToken()
                <input type="submit" value="Delete All Books" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
}
else
{
    <div class="confirm-panel">
        <div class="confirm-book-strip">
            @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
            {
                <img src="@Model.ThumbnailUrl" alt="@Model.Title" />
            }
            <div class="confirm-book-meta">
                <h3>@Model.Title</h3>
                @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                {
                    <p>@Model.Subtitle</p>
                }
                @if (Model.Authors.Any())
                {
                    <p>by @string.Join(", ", Model.Authors.Select(a => a.Name))</p>
                }
                <p>ISBN: @(Model.Isbn13 ?? Model.Isbn10)</p>
            </div>
        </div>
        <div class="alert alert-danger">
            Permanently delete <strong>@Model.Title</strong>? This cannot be undone.
        </div>
        <form asp-action="Delete" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="submit" value="Delete Book" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
}