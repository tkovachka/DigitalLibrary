@{
    ViewData["Title"] = "Import Books";
}
<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back to Books</a>
<p class="section-eyebrow">Admin · Google Books API</p>
<h1>Import Books</h1>
<hr />
<div class="form-section">
    <form asp-action="Import" method="post">
        <div class="form-group">
            <label for="query" class="control-label">Search Query or ISBN</label>
            <input type="text" id="query" name="query" class="form-control" placeholder="e.g. Harry Potter, Tolkien, 9780747532743…" required />
        </div>
        <div class="form-group">
            <label for="count" class="control-label">Number of Results</label>
            <input type="number" id="count" name="count" class="form-control" min="1" max="40" value="10" />
            <small style="color:var(--text-muted);font-size:.78rem">Max 40 books per import.</small>
        </div>
        <hr />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Import Books</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>