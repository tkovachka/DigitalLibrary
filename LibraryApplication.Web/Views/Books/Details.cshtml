@model Book
@{
    ViewData["Title"] = Model.Title;
    @using LibraryApplication.Domain.Domain
    @using Microsoft.AspNetCore.Identity
@inject UserManager<LibraryApplication.Domain.Identity.LibraryApplicationUser> UserManager
    string ratingStars = "";
    if (Model.AverageRating.HasValue)
    {
        int full = (int)Math.Floor(Model.AverageRating.Value);
        for (int s = 0; s < 5; s++) ratingStars += (s < full ? "★" : "☆");
    }
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← Back to Books</a>

<div class="book-detail-hero">
    <div class="book-detail-cover">
        @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
        {
            <img src="@Model.ThumbnailUrl" alt="@Model.Title" />
        }
        else
        {
            <div class="book-detail-cover-placeholder">📖</div>
        }
    </div>
    <div class="book-detail-info">
        @if (Model.Categories.Any())
        {
            <div class="book-detail-cats">
                @foreach (var cat in Model.Categories)
                {
                    <span class="badge badge-gold">@cat.Name</span>
                }
            </div>
        }
        <h1 class="book-detail-title">@Model.Title</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
        {
            <div class="book-detail-subtitle">@Model.Subtitle</div>
        }
        @if (Model.Authors.Any())
        {
            <div class="book-detail-authors">by @string.Join(", ", Model.Authors.Select(a => a.Name))</div>
        }
        @if (Model.AverageRating.HasValue && Model.AverageRating > 0)
        {
            <div class="book-detail-rating">
                <span>@ratingStars</span>
                <span>@Model.AverageRating?.ToString("F1") / 5</span>
                @if (Model.RatingsCount.HasValue)
                {
                    <span style="color:var(--text-muted);font-weight:400">(@Model.RatingsCount ratings)</span>
                }
            </div>
        }
        <div class="book-detail-availability @(Model.IsAvailable ? "availability-yes" : "availability-no")">
            @(Model.IsAvailable ? "✓ Available to Borrow" : "✕ Currently On Loan")
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="book-detail-description">@Model.Description</div>
        }
        <div class="book-detail-meta">
            @if (Model.Publisher != null)
            {
                <div class="book-detail-meta-item">
                    <span class="book-detail-meta-label">Publisher</span>
                    <span class="book-detail-meta-value">@Model.Publisher.Name</span>
                </div>
            }
            @if (Model.PublishedDate.HasValue)
            {
                <div class="book-detail-meta-item">
                    <span class="book-detail-meta-label">Year</span>
                    <span class="book-detail-meta-value">@Model.PublishedDate.Value.Year</span>
                </div>
            }
            @if (Model.PageCount.HasValue)
            {
                <div class="book-detail-meta-item">
                    <span class="book-detail-meta-label">Pages</span>
                    <span class="book-detail-meta-value">@Model.PageCount</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Language))
            {
                <div class="book-detail-meta-item">
                    <span class="book-detail-meta-label">Language</span>
                    <span class="book-detail-meta-value">@Model.Language.ToUpper()</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Isbn13))
            {
                <div class="book-detail-meta-item">
                    <span class="book-detail-meta-label">ISBN-13</span>
                    <span class="book-detail-meta-value">@Model.Isbn13</span>
                </div>
            }
        </div>
        <div class="book-detail-actions">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" class="btn btn-primary" asp-route-id="@Model.Id">Edit</a>
                <a asp-action="Delete" class="btn btn-danger" asp-route-id="@Model.Id">Delete</a>
            }
            else if (User.Identity?.IsAuthenticated == true)
            {
                @if ((bool)(ViewBag.UsersLoan ?? false))
                {
                    <form asp-controller="Loans" asp-action="Return" method="get" style="display:inline">
                        <input type="hidden" name="id" value="@ViewBag.LoanId" />
                        <button type="submit" class="btn btn-warning">↩ Return Book</button>
                    </form>
                }
                else if (Model.IsAvailable || (bool)(ViewBag.ActiveReservation ?? false))
                {
                    <form asp-controller="Loans" asp-action="Loan" method="get" style="display:inline">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <button type="submit" class="btn btn-success btn-lg">Borrow This Book</button>
                    </form>
                }
                else if ((bool)(ViewBag.UsersReservation ?? false))
                {
                    <form asp-controller="Reservations" asp-action="Cancel" method="get" style="display:inline">
                        <input type="hidden" name="id" value="@ViewBag.ReservationId" />
                        <button type="submit" class="btn btn-warning">Cancel Reservation</button>
                    </form>
                }
                else
                {
                    <form asp-controller="Reservations" asp-action="Reserve" method="get" style="display:inline">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary">Reserve This Book</button>
                    </form>
                }
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-success btn-lg">Log in to Borrow</a>
            }
        </div>
    </div>
</div>