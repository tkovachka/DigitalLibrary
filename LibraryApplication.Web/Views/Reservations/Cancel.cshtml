@model LibraryApplication.Domain.Domain.Reservation
@{
    ViewData["Title"] = "Cancel Reservation";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← My Reservations</a>
<p class="section-eyebrow">Confirm Cancellation</p>
<h1>Cancel Reservation</h1>
<hr />

<div class="confirm-panel">
    <div class="confirm-book-strip">
        @if (!string.IsNullOrWhiteSpace(Model.Book?.ThumbnailUrl))
        {
            <img src="@Model.Book.ThumbnailUrl" alt="" />
        }
        <div class="confirm-book-meta">
            <h3>@Model.Book?.Title</h3>
            @if (Model.Book?.Authors != null && Model.Book.Authors.Any())
            {
                <p>by @string.Join(", ", Model.Book.Authors.Select(a => a.Name))</p>
            }
            <p>Queue position: <strong>@Model.QueuePosition</strong></p>
            @if (Model.IsActive)
            {
                <p style="color:var(--gold);font-weight:600">⚠ This is an active reservation — cancelling will pass your turn to the next person.</p>
            }
        </div>
    </div>
    <div class="alert alert-danger">
        Are you sure you want to cancel your reservation for <strong>@Model.Book?.Title</strong>?
    </div>
    <form asp-action="CancelConfirm" method="post" class="d-flex gap-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Yes, Cancel Reservation</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Keep Reservation</a>
    </form>
</div>