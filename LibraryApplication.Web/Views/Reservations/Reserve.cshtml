@using LibraryApplication.Domain.Domain
@model Book
@{
    ViewData["Title"] = "Reserve Book";
}

<a asp-action="Index" asp-controller="Books" class="btn btn-outline-secondary btn-sm mb-3">← Back to Books</a>
<p class="section-eyebrow">Confirm Reservation</p>
<h1>Reserve This Book</h1>
<hr />

<div class="confirm-panel">
    <div class="confirm-book-strip">
        @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
        {
            <img src="@Model.ThumbnailUrl" alt="@Model.Title" />
        }
        <div class="confirm-book-meta">
            <h3>@Model.Title</h3>
            @if (Model.Authors.Any())
            {
                <p>by @string.Join(", ", Model.Authors.Select(a => a.Name))</p>
            }
            <p style="color:var(--danger);font-weight:600">Currently on loan</p>
        </div>
    </div>
    <div class="rules-box">
        <h4>Reservation Rules</h4>
        <ul>
            <li>You'll be added to the waiting queue for this book.</li>
            <li>When it's your turn, you'll have <strong>3 days</strong> to borrow it.</li>
            <li>If you don't borrow within 3 days, your reservation expires and the next person is notified.</li>
            <li>You can cancel your reservation at any time.</li>
        </ul>
    </div>
    <form asp-action="ReserveConfirm" method="post" class="d-flex gap-2">
        <input type="hidden" name="bookId" value="@Model.Id" />
        <button type="submit" class="btn btn-primary btn-lg">Confirm Reservation</button>
        <a asp-action="Index" asp-controller="Books" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>