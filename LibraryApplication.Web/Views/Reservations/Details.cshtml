@model LibraryApplication.Domain.Domain.Reservation
@{
    ViewData["Title"] = "Reservation Details";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">← My Reservations</a>
<p class="section-eyebrow">Reservation Details</p>
<h1>@Model.Book?.Title</h1>
<hr />

<div class="confirm-panel">
    @if (Model.IsActive)
    {
        <div class="activation-banner">
            <span class="icon">🔔</span>
            <div>
                <h4>It's your turn!</h4>
                <p>The book is reserved for you. Borrow it before your reservation expires.</p>
            </div>
        </div>
    }

    <div class="confirm-book-strip">
        @if (!string.IsNullOrWhiteSpace(Model.Book?.ThumbnailUrl))
        {
            <img src="@Model.Book.ThumbnailUrl" alt="" />
        }
        <div class="confirm-book-meta">
            <h3>@Model.Book?.Title</h3>
            @if (Model.Book?.Authors != null && Model.Book.Authors.Any())
            {
                <p>by @string.Join(", ", Model.Book.Authors.Select(a => a.Name))</p>
            }
            <p>ISBN: @Model.Book?.Isbn13</p>
            <p>Requested: @Model.DateRequested</p>
            <p>Queue position: <strong>@Model.QueuePosition</strong></p>
            @if (Model.ExpirationDate.HasValue)
            {
                <p>Expires: @Model.ExpirationDate</p>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        @if (Model.IsActive)
        {
            <a class="btn btn-success" asp-action="Loan" asp-controller="Loans" asp-route-bookId="@Model.BookId">Borrow Now</a>
        }
        <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-danger">Cancel Reservation</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>