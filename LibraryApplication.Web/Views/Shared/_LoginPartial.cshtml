@using LibraryApplication.Domain.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<LibraryApplicationUser> SignInManager
@inject UserManager<LibraryApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                   href="#" id="accountDropdown" role="button"
                   data-bs-toggle="dropdown" aria-expanded="false">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     style="opacity:0.85">
                    <circle cx="12" cy="8" r="4" />
                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                </svg>
                <span>@User.Identity?.Name</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountDropdown"
                style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);
                box-shadow:var(--shadow-md);padding:0.5rem 0;min-width:200px;">
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index"
                           style="font-size:0.85rem;padding:0.6rem 1.25rem;color:var(--text);font-family:'Source Sans 3',sans-serif;">
                        My Profile
                    </a>
                </li>
                <li><hr style="margin:0.4rem 0;border-color:var(--border)"></li>
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Books", new { area = "" })"
                          style="margin:0">
                        <button type="submit" class="dropdown-item"
                                style="font-size:0.85rem;padding:0.6rem 1.25rem;color:var(--danger);
                            font-family:'Source Sans 3',sans-serif;background:none;border:none;width:100%;text-align:left;cursor:pointer;">
                            Logout
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>